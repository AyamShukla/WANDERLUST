<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        <h4 class="fw-bold mb-1">Add a new listing</h4>
        <p class="text-muted mb-4">Share your place with the world.</p>

        <!-- enctype="multipart/form-data" is required for file upload -->
        <form method="POST" action="/listings" enctype="multipart/form-data" novalidate class="needs-validation">

            <div class="mb-3">
                <label class="form-label fw-semibold">Title</label>
                <input name="listing[title]" type="text" class="form-control rounded-3" placeholder="e.g. Cozy Beachfront Cottage" required>
                <div class="invalid-feedback">Please enter a title.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="listing[description]" class="form-control rounded-3" rows="3" placeholder="Describe your place..."></textarea>
            </div>

            <!-- FILE UPLOAD instead of URL -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Listing Image</label>
                <input name="image" type="file" class="form-control rounded-3" accept="image/*">
                <div class="form-text">Upload a photo of your place. Leave blank to use a default image.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Price per night (&#8377;)</label>
                <div class="input-group">
                    <span class="input-group-text">&#8377;</span>
                    <input name="listing[price]" type="number" class="form-control rounded-end-3" placeholder="1000" min="0" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Location</label>
                <input name="listing[location]" type="text" class="form-control rounded-3" placeholder="City or area" required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Country</label>
                <input name="listing[country]" type="text" class="form-control rounded-3" placeholder="Country" required>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger rounded-pill px-4 fw-semibold">
                    <i class="bi bi-plus-lg me-1"></i> Add Listing
                </button>
                <a href="/listings" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
            </div>

        </form>
    </div>
</div>

<script>
    (() => {
        const forms = document.querySelectorAll('.needs-validation');
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation(); }
                form.classList.add('was-validated');
            }, false);
        });
    })();
</script>
