<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <h1 class="display-1 fw-bold text-danger"><%= statusCode %></h1>
        <h4 class="fw-semibold mb-3"><%= message %></h4>
        <p class="text-muted mb-4">Something went wrong. Please try again or go back to listings.</p>
        <a href="/listings" class="btn btn-dark rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Back to Listings
        </a>
    </div>
</div>
